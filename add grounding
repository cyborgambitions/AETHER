# Example upgrade (using sentence-transformers + FAISS or Chroma)
from sentence_transformers import SentenceTransformer
import faiss
import numpy as np

embedder = SentenceTransformer("all-MiniLM-L6-v2")  # or better: "voyage-3", "bge-large", etc.

# Index your knowledge base
chunks = [...]  # your documents split into chunks
embeddings = embedder.encode(chunks, normalize_embeddings=True)
index = faiss.IndexFlatIP(embeddings.shape[1])
index.add(embeddings)

def retrieve(query, top_k=5, threshold=0.65):
    q_emb = embedder.encode([query], normalize_embeddings=True)
    scores, indices = index.search(q_emb, top_k)
    results = [chunks[i] for i, s in zip(indices[0], scores[0]) if s > threshold]
    return results, scores[0]
